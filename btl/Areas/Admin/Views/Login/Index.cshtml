@model BaiTapLon.Areas.Admin.Models.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Nhà Sách EBook</title>
    <link rel="icon" href="~/DataImage/icon-book-72-275692.png" type="image/x-icon" />

    <link href="~/Content/Client/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="~/Content/Client/css/sb-admin.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .login-wrapper {
            position: relative;
            width: 400px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            animation: fadeIn 1s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-header {
            text-align: center;
            padding: 25px 20px 10px;
            color: #fff;
        }

            .login-header h3 {
                font-weight: 600;
                font-size: 1.6rem;
            }

        .login-body {
            padding: 25px 35px 35px;
        }

        .form-group label {
            color: #f5f5f5;
            font-weight: 500;
            margin-bottom: 5px;
        }

        .form-control {
            background-color: rgba(255, 255, 255, 0.15);
            border: none;
            border-radius: 10px;
            padding: 10px 15px;
            color: #fff;
            transition: all 0.3s;
        }

            .form-control::placeholder {
                color: #ddd;
            }

            .form-control:focus {
                background-color: rgba(255, 255, 255, 0.25);
                box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
            }

        .btn-login {
            background: linear-gradient(135deg, #00b4db, #0083b0);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-weight: 600;
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #0083b0, #00b4db);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 179, 219, 0.4);
            }

        .text-center a {
            color: #d0e7ff;
            font-size: 0.9rem;
        }

            .text-center a:hover {
                color: #fff;
                text-decoration: underline;
            }

        .glow-circle {
            position: absolute;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle at center, rgba(0, 180, 219, 0.4), transparent);
            border-radius: 50%;
            top: -50px;
            right: -50px;
            animation: float 6s ease-in-out infinite alternate;
        }

        .glow-circle2 {
            position: absolute;
            width: 120px;
            height: 120px;
            background: radial-gradient(circle at center, rgba(0, 150, 255, 0.3), transparent);
            border-radius: 50%;
            bottom: -40px;
            left: -40px;
            animation: float 7s ease-in-out infinite alternate-reverse;
        }

        @@keyframes float {
            from {
                transform: translateY(0px);
            }

            to {
                transform: translateY(20px);
            }
        }

        .checkbox label {
            color: #fff;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="glow-circle"></div>
        <div class="glow-circle2"></div>
        <div class="login-header">
            <h3><i class="fas fa-book-reader"></i> Nhà Sách EBook</h3>
        </div>
        <div class="login-body">
            @using (Html.BeginForm("Login", "Login", FormMethod.Post))
            {
                @Html.ValidationSummary(false, "", new { @class = "text-warning mb-3" })

                <div class="form-group">
                    @Html.LabelFor(model => model.userName, "Tài khoản")
                    @Html.TextBoxFor(model => model.userName, new { @class = "form-control", @placeholder = "Nhập tài khoản", @autofocus = "autofocus" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.passWord, "Mật khẩu")
                    @Html.PasswordFor(model => model.passWord, new { @class = "form-control", @placeholder = "Nhập mật khẩu" })
                </div>

                <div class="form-group form-check">
                    @Html.CheckBoxFor(model => model.Remember, new { @class = "form-check-input" })
                    <label class="form-check-label">Ghi nhớ tôi</label>
                </div>

                <button type="submit" class="btn btn-login">Đăng nhập</button>
            }

            <div class="text-center mt-4">
                <a href="#">Quên mật khẩu?</a><br />
                <a href="#">Tạo tài khoản mới</a>
            </div>
        </div>
    </div>

    <script src="~/Content/Client/vendor/jquery/jquery.min.js"></script>
    <script src="~/Content/Client/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
