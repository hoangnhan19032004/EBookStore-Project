@model Mood.EF2.Orders
@using Mood.EF2
@using Mood.Draw

@{
    ViewBag.Title = "Thanh toán thành công";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";

    long sum = ViewBag.Sum != null ? Convert.ToInt64(ViewBag.Sum) : 0;

    var listOrderDetails = ViewBag.listCart as List<Order_Detail>
                            ?? new List<Order_Detail>();

    var draw = new SanphamDraw();
}

<!-- ====== MAIN CONTENT ===== -->
<main id="content">
    <div class="bg-gray-200 space-bottom-3">
        <div class="container">

            <div class="py-5">
                <h3 class="text-success text-center">
                    ✅ Thanh toán thành công
                </h3>
            </div>

            <div class="max-width-900 mx-auto">
                <div class="bg-white border p-4 rounded shadow-sm">

                    <!-- ===== ORDER INFO ===== -->
                    <table class="table table-bordered text-center mb-4">
                        <thead class="thead-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày tạo</th>
                                <th>Tổng tiền</th>
                                <th>Phương thức</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>#@Model.IDOder</td>
                                <td>
                                    @(Model.NgayTao != null
                                        ? Convert.ToDateTime(Model.NgayTao).ToString("dd/MM/yyyy")
                                        : "")
                                </td>
                                <td class="text-success font-weight-bold">
                                    @sum.ToString("N0") đ
                                </td>
                                <td>@ViewBag.Methodpayment</td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ===== DETAILS ===== -->
                    <h5 class="mb-3">📦 Chi tiết đơn hàng</h5>

                    @if (listOrderDetails.Any())
                    {
                        foreach (var item in listOrderDetails)
                        {
                            var product = draw.getByID(item.ProductID);

                            <div class="d-flex justify-content-between border-bottom py-2">

                                <div>
                                    <strong>@product.Name</strong><br />
                                    <small class="text-muted">@product.TacGia</small><br />
                                    Số lượng: <strong>x @item.Quanlity</strong>
                                </div>

                                <div class="font-weight-bold">
                                    @((item.Price ?? 0m).ToString("N0")) đ
                                </div>


                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning text-center">
                            ❌ Không có sản phẩm trong đơn hàng.
                        </div>
                    }

                    <!-- ===== SUMMARY ===== -->
                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex justify-content-between">
                            <span>Tổng phụ:</span>
                            <strong>@sum.ToString("N0") đ</strong>
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Vận chuyển:</span>
                            <span>Miễn phí</span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Thanh toán:</span>
                            <strong>@ViewBag.Methodpayment</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between h5">
                            <span>TỔNG CỘNG:</span>
                            <strong class="text-success">
                                @sum.ToString("N0") đ
                            </strong>
                        </div>
                    </div>

                    <!-- ===== ADDRESSES ===== -->
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h6>📍 Địa chỉ thanh toán</h6>
                            <p class="mb-0">@Model.ShipAddress</p>
                        </div>

                        <div class="col-md-6">
                            <h6>🚚 Địa chỉ nhận hàng</h6>
                            <p class="mb-0">@Model.ShipAddress</p>
                        </div>
                    </div>

                    <!-- ===== BUTTONS ===== -->
                    <div class="text-center mt-4">

                        <a href="/gio-hang" class="btn btn-outline-dark mr-2">
                            🛒 Mua tiếp
                        </a>

                        <a href="/trang-chu" class="btn btn-primary">
                            🏠 Về trang chủ
                        </a>

                    </div>

                </div>
            </div>

        </div>
    </div>
</main>
